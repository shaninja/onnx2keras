{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodexReview",
  "type": "object",
  "required": [
    "status",
    "summary",
    "findings",
    "prompt_for_claude",
    "ready_to_push"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "approved",
        "approved_with_notes",
        "changes_requested",
        "blocked"
      ]
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "category",
          "title",
          "detail",
          "file",
          "line",
          "must_fix",
          "suggested_fix"
        ],
        "properties": {
          "id": {"type": "string"},
          "severity": {
            "type": "string",
            "enum": ["nit", "low", "medium", "high", "blocker"]
          },
          "category": {"type": "string"},
          "title": {"type": "string"},
          "detail": {"type": "string"},
          "file": {"type": "string"},
          "line": {"type": "integer"},
          "must_fix": {"type": "boolean"},
          "suggested_fix": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "prompt_for_claude": {
      "type": "string"
    },
    "ready_to_push": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
